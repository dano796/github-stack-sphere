{
  "version": 2,
  "rewrites": [{ "source": "/stack.svg", "destination": "/api/stack" }],
  "functions": {
    "api/stack.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
